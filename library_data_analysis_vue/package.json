  "description": "图书馆数据分析系统前端 - 提供借阅数据可视化、读者行为分析、图书热度统计等功能",
  "type": "module",
  "author": "Library Data Analysis Team",
  "license": "MIT",
  "keywords": [
    "library",
    "data-analysis",
    "vue3",
    "visualization",
    "dashboard"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/library-data-analysis/system.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.ts --fix",
